  <% if (diceSystem === 100) { %>
    <%= data < 50 ? color = " success" : data > 50 ? color = " fail" : " black" %>
    
  <% } else if (diceSystem === 20) { %>
    <% if (systemOrder === "ASC") { %>
      <%= data < 10 ? color = " success" : data > 10 ? color = " fail" : " black" %>
    <% } else if (systemOrder === "DESC") { %>
      <%= data > 10 ? color = " success" : data < 10 ? color = " fail" : " black" %>
    <% } %>
  <% } %>

