  <div class="flex-row-center">
    <img class="img-icon-bg" src="/static/images/circle-user.svg" alt="Connecté">
    <a href="/logout" class="icon nav-icon <%= slug %>-color">
      <img src="/static/images/logout.png" alt="[->" class="img-icon <%= slug %>-img-bg">
