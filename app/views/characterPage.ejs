<%- include('partials/header') %>
<%- include('partials/navigation', {rpgData, rpgList, pageTitle: character }) %>

<main class="main-row mb-20" id="character-main-page">
  <section class="col-section w30 mb-20">
    <h2 class="black">Statistiques globales</h2>
    <article class="<%= rpgData.slug %>-color card w60">
      <p><b>Moyenne globale :</b> <%= rpgData.stats[character].globalAvg %></p>
      <p><b>Médiane globale :</b> <%= rpgData.stats[character].globalMedian %></p>
      <p><b>Réussites critiques :</b> <%= rpgData.stats[character].globalSuccess %></p>
      <p><b>Échecs critiques : </b><%= rpgData.stats[character].globalFail %></p>
    </article>
  </section>
  
  <section class="col-section black">
    <h2 class="black">Histogramme des dés de la campagne</h2>

    <img src="/static/images/hist-<%= character %>.png" alt="" id="histogram">
    <legend>La ligne rouge représente les statistiques attendues selon les probabilités</legend>
  </section>
</main>


<section class="col-section black">
  <h2>Liste détaillée des dés</h2>

  <table>
    <thead>
      <tr>
      <th>Nombre du dé</th>
      <% for (const [dice, occ] of Object.entries(counts)) { %>
        <td><%= dice %></td>
      <% } %>
      </tr>
    </thead>
    <tbody>
      <tr>
        <th>Nombre obtenu</th>
      <% for (const [dice, occ] of Object.entries(counts)) { %>
        <td><%= occ %></td>
      <% } %>
      </tr>
    </tbody>
  </table>
</section>

<%- include('partials/footer') %>