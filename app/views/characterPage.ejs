<%- include('partials/header') %>
<%- include('partials/navigation', {rpgData, rpgList, pageTitle: character }) %>

<main class="main-col">
  <div class="main-row mb-20" id="character-main-page">
    <section class="col-section w30 mb-20">
      <h2 class="black">Statistiques globales</h2>
      <article class="<%= rpgData.slug %>-color card w60">
        <p><b>Moyenne globale :</b> <%= rpgData.stats[character].globalAvg %></p>
        <p><b>Médiane globale :</b> <%= rpgData.stats[character].globalMedian %></p>
        <p><b>Réussites critiques :</b> <%= rpgData.stats[character].globalSuccess %></p>
        <p><b>Échecs critiques : </b><%= rpgData.stats[character].globalFail %></p>
      </article>
    </section>
    
    <section class="col-section black w70">
      <h2 class="black">Histogramme des dés de la campagne</h2>
      <img src="/static/images/hist-<%= character %>.png" alt="" id="histogram">
      <legend>La ligne rouge représente les statistiques attendues selon les probabilités</legend>
    </section>
  </div>

  <section class="dice-list-section">
    <h2>Liste détaillée des dés</h2>
  
    <ul class="table">
      <li class="<%= rpgData.slug %>-color">
        <h4>Valeur du dé</h4>
        <div></div>
        <p>Occurrences</p>
      </li>
      <% for (const [dice, occ] of Object.entries(counts)) { %>
        <% if (dice < 51) { %>
          <li>
            <h4><%= dice %></h4>
            <div></div>
            <% if (occ === min) { %>
              <p class="success bold"><%= occ %></p>
            <% } else if (occ === max) { %>
              <p class="fail bold"><%= occ %></p>
            <% } else { %>
              <p><%= occ %></p>
            <% } %>
          </li>
        <% } %>
      <% } %>
    </ul>
  
    <% if (rpgData.diceSystem === 100) { %>
      <ul class="table">
        <li class="<%= rpgData.slug %>-color">
          <h4>Valeur du dé</h4>
          <div></div>
          <p>Occurrences</p>
        </li>
        <% for (const [dice, occ] of Object.entries(counts)) { %>
          <% if (dice > 50) { %>
            <li>
              <h4><%= dice %></h4>
              <div></div>
              <% if (occ === min) { %>
                <p class="success bold"><%= occ %></p>
              <% } else if (occ === max) { %>
                <p class="fail bold"><%= occ %></p>
              <% } else { %>
                <p><%= occ %></p>
              <% } %>
            </li>
          <% } %>
        <% } %>
      </ul>
    <% } %>
  
    <div class="flex-row-around" id="legend">
      <div class="flex-row-center">
        <div class="bg-fail square mr-10"></div>
        Nombre maximum d'occurrences obtenues
      </div>
      <div class="flex-row-center">
        <div class="bg-success square mr-10"></div>
        Nombre minimum d'occurrences obtenues
      </div>
    </div>
  </section>
</main>


<%- include('partials/footer') %>