<%- include('partials/header') %>

<%- include('partials/navigation', {rpgData, rpgList, pageTitle: rpgData.name}) %>

<main class="new-game__main">
  <h1 class="new-game__main-title">Nouvelle partie</h1>
  
  <form action="/add-game/<%= rpg %>" method="post" class="new-game__main-form <%= rpg %>-color">
    <div class="mb-4">
      <label for="date">Date de la partie :</label>
      <input type="date" name="date" id="date" required class="bg-white text-black">
    </div>

    <% characters.forEach(character => { %>
      <div class="character-div">
        <h3 class="new-game__main-form_subtitle"><%= character %></h3>

        <div>
          <label for="<%= character %>-dices">Liste des dés :</label>
          <input type="text" name="<%= character %>" id="<%= character %>-dices" class="dices-list bg-white text-black" pattern="^((([0-9]){1,3}),\s?)*([0-9]{1,3})$">
        </div>
      </div>
    <% }); %>

    <section class="new-game__main-form_final-section">
      <h3 class="new-game__main-form_subtitle">Campagne terminée :</h3>
      <div>
        <input type="radio" name="status" id="status-true" value="true">
        <label for="status-true">Oui</label>
      </div>
      <div>
        <input type="radio" name="status" id="status-false" value="false" checked>
        <label for="status-false">Non</label>
      </div>
    </section>

    <button type="submit" class="button button-<%= rpg %> <%= rpg === "dernierepluie" && "button-submit-dernierepluie" %> form-button">Valider</button>
  </form>
</main>
 
<%- include('partials/footer') %>